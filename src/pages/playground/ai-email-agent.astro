---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card/index.astro";
import { SITE } from "../../site-config";
---

<Layout 
  title={`AI Email Agent | ${SITE.author.fullName}`} 
  description="Case study for an autonomous AI email reading and routing system."
>
  <main class="text-white m-auto p-4 md:p-8 max-w-4xl mt-10">
    <a href="/" class="text-primary hover:underline mb-8 inline-block transition-colors">← Back to Grid</a>
    
    <h1 class="text-4xl md:text-5xl font-bold mb-4">AI Email Agent</h1>
    <p class="text-xl text-neutral-400 mb-10">Autonomous email reading, summarization, and Discord routing.</p>
    
    <div class="grid gap-4 md:grid-cols-2 mb-4">
       <Card title="The Problem" colSpan="md:col-span-1" rowSpan="md:row-span-1">
         <p class="text-sm text-neutral-300 mt-2">
           Business owners lose hours daily sorting through cluttered inboxes, often missing critical updates or high-value leads buried under automated spam.
         </p>
       </Card>
       <Card title="The Solution" colSpan="md:col-span-1" rowSpan="md:row-span-1">
         <p class="text-sm text-neutral-300 mt-2">
           A custom Python agent that securely monitors an inbox via IMAP. It leverages LLMs to evaluate and summarize important threads, then pushes a concise TL;DR directly to a private Discord channel.
         </p>
       </Card>
    </div>

    <Card title="The Tech Stack" colSpan="md:col-span-2" rowSpan="md:row-span-1">
      <ul class="flex flex-wrap gap-3 mt-4">
        <li class="bg-neutral-800 border border-neutral-700 px-4 py-1 rounded-full text-sm font-mono">Python 3</li>
        <li class="bg-neutral-800 border border-neutral-700 px-4 py-1 rounded-full text-sm font-mono">CrewAI / LLMs</li>
        <li class="bg-neutral-800 border border-neutral-700 px-4 py-1 rounded-full text-sm font-mono">Discord Webhooks</li>
        <li class="bg-neutral-800 border border-neutral-700 px-4 py-1 rounded-full text-sm font-mono">IMAP Protocol</li>
      </ul>
    </Card>

    <div class="mt-8 rounded-xl overflow-hidden border border-neutral-800 bg-[#0c0c0c] font-mono text-sm shadow-2xl">
      
      <div class="flex items-center px-4 py-3 bg-neutral-900 border-b border-neutral-800">
        <div class="flex space-x-2">
          <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
        </div>
        <p class="ml-4 text-xs text-neutral-500 flex-1 text-center mr-10">ezradante@EzraDante: ~/projects/ai-agent</p>
      </div>
      
      <div class="p-4 md:p-6 text-green-400 min-h-[280px]">
        <p class="text-neutral-300">ezradante@EzraDante:~/projects/ai-agent$ <span class="text-white">python3 main.py</span></p>
        
        <div class="mt-3 space-y-2">
          <p class="line opacity-0">[+] Connecting to IMAP server (mail.client.com)... <span class="text-blue-400">SUCCESS</span></p>
          <p class="line opacity-0">[+] Scanning inbox for unread messages... <span class="text-yellow-400">1 found.</span></p>
          <p class="line opacity-0">[+] Fetching email ID #8932 (Subject: "Need Automation Help")</p>
          <p class="line opacity-0">[+] Initializing CrewAI LLM for summarization...</p>
          <p class="line opacity-0">[+] Analysis complete. Extracting key deliverables & budget.</p>
          
          <div class="line opacity-0 text-white border-l-2 border-green-500 pl-3 my-3 py-2 bg-green-500/10">
            <p class="font-bold text-green-300 mb-1">DISCORD PAYLOAD PREVIEW:</p>
            <p>SUMMARY: Client needs a Python web scraper built.</p>
            <p>BUDGET: $500. DEADLINE: Friday.</p>
          </div>
          
          <p class="line opacity-0">[+] Routing payload to Discord Webhook... <span class="text-blue-400">DELIVERED</span></p>
          <p class="line opacity-0 flex items-center">[+] Waiting for new emails... <span class="animate-pulse w-2 h-4 bg-green-400 ml-1 inline-block"></span></p>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const loader = document.querySelector('.loader');
      if (loader) loader.remove();
    });
  </script>
</Layout>

<style>
  .line {
    animation: appear 0.1s forwards;
  }
  
  /* This staggers the text so it looks like it's processing in real-time */
  .line:nth-child(1) { animation-delay: 0.8s; }
  .line:nth-child(2) { animation-delay: 1.5s; }
  .line:nth-child(3) { animation-delay: 2.0s; }
  .line:nth-child(4) { animation-delay: 2.8s; }
  .line:nth-child(5) { animation-delay: 4.5s; } /* LLM takes a second to think! */
  .line:nth-child(6) { animation-delay: 4.8s; }
  .line:nth-child(7) { animation-delay: 5.5s; }
  .line:nth-child(8) { animation-delay: 6.0s; }

  @keyframes appear {
    to {
      opacity: 1;
    }
  }
</style>
