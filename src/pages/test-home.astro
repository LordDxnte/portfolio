---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
import IntroCard from "../components/IntroCard.astro";
import ContactsCard from "../components/ContactsCard.astro";
import ThemeChangeCard from "../components/ThemeChangeCard.astro";
import TimeZone from "../components/TimeZoneCard.astro";
import AboutMe from "../components/AboutMe.astro";
import Now from "../components/Now.astro";
import { SITE } from "../site-config";
---

<script>
  import { stagger, animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";
  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        type: "spring",
        at: "-0.1",
        delay: stagger(0.2),
      },
    ],
  ];

  animate(sequence as AnimationSequence);
</script>

<Layout
  description={`I'm an AI & Automation Developer based in ${SITE.location.countryName}, specializing in Python, LLMs, and secure workflow macros.`}
  title={`${SITE.author.fullName} - ${SITE.author.jobTitle}`}
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl overflow-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px]"
  >
    <IntroCard />
    <AboutMe />
    <ContactsCard />
    <TimeZone />
    <Now />

    <Card
      colSpan="md:col-span-2"
      rowSpan="md:row-span-2"
      title="Featured Projects"
    >
      <div class="flex flex-col gap-6 mt-4">
        <div class="group">
         <a  href="/playground/ai-email-agent" class="block hover:opacity-80 transition-opacity">
            <h3 class="font-bold text-lg text-primary flex items-center gap-2">
              AI Email Agent <span class="text-sm opacity-0 group-hover:opacity-100 transition-opacity text-neutral-400">→</span>
            </h3>
            <p class="text-sm text-neutral-300 mt-1">
              A Python-based system using LLMs and IMAP to autonomously read, summarize, and route important emails via Discord webhooks.
            </p>
          </a>
        </div>
        <div class="group">
          <a href="/playground/workflow-macros" class="block hover:opacity-80 transition-opacity">
            <h3 class="font-bold text-lg text-primary flex items-center gap-2">
              Visual Automation Engine <span class="text-sm opacity-0 group-hover:opacity-100 transition-opacity text-neutral-400">→</span>
            </h3>
            <p class="text-sm text-neutral-300 mt-1">
              Secure, Linux-native automation scripts featuring visual environment detection and remote alerting systems.
            </p>
          </a>
        </div>
      </div>
    </Card>

    <ThemeChangeCard />

    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <p class="text-xs">
        © 2026 · Crafted with ♥️ using <a
          class="hover:underline text-primary"
          href="https://astro.build/"
          target="_blank">Astro</a
        > by {SITE.author.shortName}.
      </p>
    </Card>
  </main>
</Layout>
